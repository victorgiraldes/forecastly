<%= content_for :title, "Forecastly" %>

<div class="search-container">
  <h1>Get the forecast</h1>

  <form class="search-form" method="get" action="<%= forecast_path %>">
    <label for="zip_code">ZIP Code</label>
    <input
      type="text"
      id="zip_code"
      name="zip_code"
      placeholder="e.g. 90210"
      maxlength="5"
      inputmode="numeric"
      pattern="\d{5}"
      autocomplete="postal-code"
      required
    >
    <button type="submit">Search</button>
  </form>

  <% if flash[:alert] %>
    <p class="alert"><%= flash[:alert] %></p>
  <% end %>
</div>
