<%= content_for :title, "Forecastly" %>

<div class="search-container">
  <h1>Get the forecast</h1>

  <form class="search-form" method="get" action="<%= forecast_path %>">
    <label for="location">Address or ZIP code</label>
    <input
      type="text"
      id="location"
      name="location"
      placeholder="e.g. 90210 or 1 Main St, Springfield, IL"
      autocomplete="off"
      required
    >
    <button type="submit">Search</button>
  </form>

  <% if flash[:alert] %>
    <p class="alert"><%= flash[:alert] %></p>
  <% end %>
</div>
